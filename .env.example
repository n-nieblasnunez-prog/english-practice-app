# ============================================================
# English Practice App — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# OpenAI API key (required) — used for Whisper speech-to-text
# Get yours at https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-...

# Anthropic API key (required) — used for Claude grammar feedback
# Get yours at https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Azure Cognitive Services Speech (optional) — enables pronunciation scoring
# Create a resource at https://portal.azure.com → Azure AI services → Speech
VITE_AZURE_SPEECH_KEY=your-azure-speech-key
VITE_AZURE_SPEECH_REGION=eastus
